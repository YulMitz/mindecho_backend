
model ChatSession {
  id            String      @id @default(cuid())
  sessionId     String      @unique @default(cuid())
  userId        String
  title         String?
  chatbotType   ChatbotType @default(INITIAL)
  provider      LLMProvider @default(GEMINI)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  messages      Message[]

  @@map("chat_sessions")
}

model Message {
  id            String      @id @default(cuid())
  sessionId     String
  userId        String
  messageType   MessageType
  chatbotType   ChatbotType @default(INITIAL)
  provider      LLMProvider?
  content       String      @db.Text
  metadata      Json?
  timestamp     DateTime    @default(now())
  digestedAt    DateTime?

  // Relations
  session       ChatSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@map("messages")
}

enum ChatbotType {
  MBT
  CBT
  MBCT
  DBT
  INITIAL
}

enum MessageType {
  USER
  MODEL
}

enum LLMProvider {
  GEMINI
  ANTHROPIC
}
